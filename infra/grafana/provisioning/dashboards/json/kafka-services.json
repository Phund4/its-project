{
  "annotations": { "list": [] },
  "description": "Kafka ingest (analytics consumer, телеметрия) и доступность сервисов из prometheus.yml.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true }
      },
      "targets": [
        {
          "expr": "sum by (topic) (rate(analytics_kafka_ingest_processed_total[5m]))",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "title": "Analytics: сообщения из Kafka (по топикам)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "showPoints": "never" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(rate(data_ingestion_bus_telemetry_forwarded_total[5m]))",
          "legendFormat": "forwarded",
          "refId": "A"
        }
      ],
      "title": "Data ingestion: телеметрия переслана",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 35,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": true
          },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true }
      },
      "targets": [
        {
          "expr": "1 - up{job=~\"analytics|ml_gateway|data_ingestion|map_portal\"}",
          "legendFormat": "{{job}} — {{instance}}",
          "refId": "A"
        }
      ],
      "title": "Падения сервисов (1 = /metrics не отвечает)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" } }, "type": "value" },
            { "options": { "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" }
          ],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none"
        }
      },
