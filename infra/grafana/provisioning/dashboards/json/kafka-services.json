      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true }
      },
      "targets": [
        {
          "expr": "sum by (topic) (rate(analytics_kafka_ingest_processed_total[5m]))",
          "legendFormat": "{{topic}}",
          "refId": "A"
